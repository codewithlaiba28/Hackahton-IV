{
    "version": 2,
    "builds": [
        {
            "src": "Complete-project/frontend/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "Complete-project/backend/api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "Complete-project/backend/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "Complete-project/frontend/$1",
            "continue": true
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/_next/(.*)",
            "dest": "Complete-project/frontend/_next/$1"
        }
    ]
}