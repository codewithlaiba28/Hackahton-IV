# Database Configuration
DATABASE_URL=postgresql+async://user:password@localhost:5432/course_companion

# Cloudflare R2 Configuration
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=course-companion-content

# Application Configuration
APP_ENV=development
SECRET_KEY=your-secret-key-for-jwt-generation
API_KEY_HEADER=X-API-Key

# CORS Configuration
CHATGPT_APP_ORIGIN=https://chat.openai.com

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Phase 2: Hybrid Intelligence Configuration
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1000
ADAPTIVE_PATH_MAX_COST_USD=0.05
ASSESSMENT_MAX_COST_USD=0.03
USER_MONTHLY_LLM_CAP_USD=2.00
